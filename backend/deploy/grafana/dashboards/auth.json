{
  "uid": "playarena-auth",
  "title": "PlayArena — Auth",
  "tags": ["playarena"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Login Attempts / sec by Result",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum by (result) (rate(playarena_auth_login_attempts_total[1m]))",
        "legendFormat": "{{result}}"
      }]
    },
    {
      "id": 2,
      "title": "Token Refresh / sec by Result",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "sum by (result) (rate(playarena_auth_token_refresh_total[1m]))",
        "legendFormat": "{{result}}"
      }]
    },
    {
      "id": 3,
      "title": "Token Replay Detections",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [{
        "expr": "increase(playarena_auth_token_replay_detections_total[1h])",
        "legendFormat": "replays (1h)"
      }]
    },
    {
      "id": 4,
      "title": "Password Reset Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "targets": [{
        "expr": "increase(playarena_auth_password_reset_requests_total[1h])",
        "legendFormat": "resets (1h)"
      }]
    },
    {
      "id": 5,
      "title": "Login Failure Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "sum(rate(playarena_auth_login_attempts_total{result!=\"success\"}[5m])) / sum(rate(playarena_auth_login_attempts_total[5m]))",
        "legendFormat": "failure rate"
      }]
    }
  ]
}
