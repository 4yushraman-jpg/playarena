# Application
APP_ENV=development
APP_PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/playarena?sslmode=disable

# Security — replace before deploying to any non-local environment
JWT_SECRET=change-me

# Frontend base URL — used to build links in verification and password-reset
# emails (e.g. http://localhost:3000/verify-email?token=...). This must point
# at the FRONTEND, not the API. Must begin with https:// in production.
# APP_BASE_URL is honoured as a legacy fallback when FRONTEND_URL is unset.
FRONTEND_URL=http://localhost:3000

# Email delivery — "log" prints emails to stdout (dev default), "smtp" works
# with MailHog (docker-compose), "ses" for production.
EMAIL_PROVIDER=log
EMAIL_FROM_ADDRESS=noreply@playarena.dev
